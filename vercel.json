{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/:path*"
    },
    {
      "source": "/:path((?!assets).*)",
      "destination": "/index.html"
    }
  ]
}
